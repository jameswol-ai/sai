{
  "dashboard": {
    "id": null,
    "title": "SAI Trading Bot Monitoring",
    "panels": [
      {
        "id": 1,
        "title": "PnL Over Time",
        "type": "graph",
        "datasource": "Prometheus",
        "targets": [
          { "expr": "sai_pnl", "legendFormat": "PnL (USD)" }
        ],
        "yaxes": [
          { "format": "currencyUSD", "label": "PnL", "min": null },
          { "format": "short" }
        ]
      },
      {
        "id": 2,
        "title": "Trade Latency",
        "type": "graph",
        "datasource": "Prometheus",
        "targets": [
          { "expr": "histogram_quantile(0.95, sum(rate(sai_trade_latency_seconds_bucket[5m])) by (le))", "legendFormat": "95th Percentile Latency" }
        ],
        "yaxes": [
          { "format": "s", "label": "Latency (seconds)" },
          { "format": "short" }
        ]
      },
      {
        "id": 3,
        "title": "Rollbacks & CI/CD Failures",
        "type": "graph",
        "datasource": "Prometheus",
        "targets": [
          { "expr": "increase(helm_release_rollback_total{release=\"sai-bot\"}[5m])", "legendFormat": "Helm Rollbacks" },
          { "expr": "increase(ci_cd_deploy_failures_total{job=\"helm-deploy-production\"}[5m])", "legendFormat": "CI/CD Failures" }
        ],
        "yaxes": [
          { "format": "short", "label": "Events", "min": 0 },
          { "format": "short" }
        ]
      },
      {
        "id": 4,
        "title": "PnL vs Deployment Events",
        "type": "graph",
        "datasource": "Prometheus",
        "targets": [
          { "expr": "sai_pnl", "legendFormat": "PnL (USD)" },
          { "expr": "increase(helm_release_rollback_total{release=\"sai-bot\"}[5m])", "legendFormat": "Rollbacks" },
          { "expr": "increase(ci_cd_deploy_failures_total{job=\"helm-deploy-production\"}[5m])", "legendFormat": "CI/CD Failures" }
        ],
        "yaxes": [
          { "format": "currencyUSD", "label": "PnL", "min": null },
          { "format": "short", "label": "Events", "min": 0 }
        ]
      }
    ]
  }
}
