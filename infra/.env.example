# --- Broker / API Keys ---
BROKER_API_KEY=your_broker_api_key_here
BROKER_API_SECRET=your_broker_api_secret_here

# --- Database ---
POSTGRES_USER=sai_user
POSTGRES_PASSWORD=sai_pass
POSTGRES_DB=sai_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Logging / Monitoring ---
LOG_LEVEL=INFO
PROMETHEUS_HOST=prometheus
PROMETHEUS_PORT=9090
GRAFANA_HOST=grafana
GRAFANA_PORT=3000

# --- Bot Config ---
BOT_PORT=8080
BOT_ENV=development
