# models/train.py
import pandas as pd
from sklearn.linear_model import LinearRegression
import pickle

def train_model(data_path="data/market.csv", model_path="models/model.pkl"):
    # Load your dataset
    df = pd.read_csv(data_path)
    X = df.drop(columns=["Close"])   # features
    y = df["Close"]                  # target

    # Train a simple model
    model = LinearRegression()
    model.fit(X, y)

    # Save the model
    with open(model_path, "wb") as f:
        pickle.dump(model, f)

    print(f"Model trained and saved to {model_path}")

if __name__ == "__main__":
    train_model()


# models/load_model.py
import pickle

def load_model(model_path="models/model.pkl"):
    with open(model_path, "rb") as f:
        model = pickle.load(f)
    return model

if __name__ == "__main__":
    model = load_model()
    print("Model loaded successfully")
